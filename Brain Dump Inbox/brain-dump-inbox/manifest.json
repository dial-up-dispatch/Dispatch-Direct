{
  "manifest_version": 3,
  "name": "Brain Dump Inbox",
  "version": "1.0.1",
  "description": "A local-first thought capture tool for your Opera sidebar. Dump ideas and export as Markdown. No servers. No accounts.",
  "sidebar_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_panel": "panel.html",
    "default_title": "Brain Dump Inbox"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
